---
import Layout from "@/layouts/Layout.astro";
import NavSidebar from "@/components/NavSidebar.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

if (!SITE.isTemplate) {
  return Astro.redirect("/");
}
---

<Layout title={`Documentation | ${SITE.title}`}>
  <NavSidebar />
  <main id="main-content" class="app-layout main-content">
    <article class="docs-page">

      <header class="docs-hero">
        <div class="docs-hero-badge">Documentation</div>
        <h1 class="docs-hero-title">Sora Template</h1>
        <p class="docs-hero-subtitle">
          A portfolio template for developers, researchers, and creators.<br/>
          Configure one file. Add your works. Deploy.
        </p>
      </header>

      <!-- Quick Start -->
      <section class="docs-section">
        <h2 class="docs-heading" id="quick-start">Quick Start</h2>
        <div class="docs-steps">
          <div class="docs-step">
            <span class="docs-step-num">1</span>
            <div class="docs-step-body">
              <h3>Clone the template</h3>
              <pre class="docs-code"><code>git clone https://github.com/sandeepyadav1478/sora.git my-portfolio
cd my-portfolio && pnpm install</code></pre>
            </div>
          </div>
          <div class="docs-step">
            <span class="docs-step-num">2</span>
            <div class="docs-step-body">
              <h3>Edit <code>src/config.ts</code></h3>
              <p>All your personal data lives in one file — name, role, socials, skills, experience.</p>
            </div>
          </div>
          <div class="docs-step">
            <span class="docs-step-num">3</span>
            <div class="docs-step-body">
              <h3>Add works to <code>src/data/works/</code></h3>
              <p>Each work is a markdown file. Delete the sample files and add yours.</p>
            </div>
          </div>
          <div class="docs-step">
            <span class="docs-step-num">4</span>
            <div class="docs-step-body">
              <h3>Deploy</h3>
              <pre class="docs-code"><code>git push  # GitHub Actions auto-deploys to Pages</code></pre>
            </div>
          </div>
        </div>
      </section>

      <!-- Board Layouts -->
      <section class="docs-section">
        <h2 class="docs-heading" id="layouts">Board Layouts</h2>
        <p class="docs-text">Set <code>BOARD.layout</code> in config. Four options available:</p>

        <div class="docs-layout-grid">
          <div class="docs-layout-card">
            <div class="docs-layout-preview docs-preview-twotier">
              <div class="docs-mock-card docs-mock-lg"></div>
              <div class="docs-mock-card docs-mock-lg"></div>
              <div class="docs-mock-row"></div>
              <div class="docs-mock-row"></div>
              <div class="docs-mock-row"></div>
            </div>
            <div class="docs-layout-info">
              <h3>two-tier</h3>
              <p>Featured items as rich cards, rest as compact rows</p>
            </div>
          </div>
          <div class="docs-layout-card">
            <div class="docs-layout-preview docs-preview-flat">
              <div class="docs-mock-card docs-mock-full"></div>
              <div class="docs-mock-card docs-mock-full"></div>
              <div class="docs-mock-card docs-mock-full"></div>
            </div>
            <div class="docs-layout-info">
              <h3>flat</h3>
              <p>Every item as a full-width card</p>
            </div>
          </div>
          <div class="docs-layout-card">
            <div class="docs-layout-preview docs-preview-grid">
              <div class="docs-mock-card docs-mock-sm"></div>
              <div class="docs-mock-card docs-mock-sm"></div>
              <div class="docs-mock-card docs-mock-sm"></div>
              <div class="docs-mock-card docs-mock-sm"></div>
              <div class="docs-mock-card docs-mock-sm"></div>
              <div class="docs-mock-card docs-mock-sm"></div>
            </div>
            <div class="docs-layout-info">
              <h3>grid</h3>
              <p>Responsive thumbnail grid</p>
            </div>
          </div>
          <div class="docs-layout-card">
            <div class="docs-layout-preview docs-preview-timeline">
              <div class="docs-mock-timeline-line"></div>
              <div class="docs-mock-dot"></div>
              <div class="docs-mock-row docs-mock-tl"></div>
              <div class="docs-mock-dot"></div>
              <div class="docs-mock-row docs-mock-tl"></div>
              <div class="docs-mock-dot"></div>
              <div class="docs-mock-row docs-mock-tl"></div>
            </div>
            <div class="docs-layout-info">
              <h3>timeline</h3>
              <p>Vertical chronological timeline</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Card Styles -->
      <section class="docs-section">
        <h2 class="docs-heading" id="card-styles">Card Styles</h2>
        <p class="docs-text">Set <code>cardStyle</code> in work frontmatter for per-card visual treatment:</p>

        <div class="docs-card-style-grid">
          <div class="docs-demo-card-wrap">
            <div class="grid-card">
              <h3 class="grid-card-title">Sample Work</h3>
              <p class="grid-card-desc">Standard appearance</p>
            </div>
            <span class="docs-demo-style-label">default</span>
          </div>
          <div class="docs-demo-card-wrap card-design--glass">
            <div class="grid-card">
              <h3 class="grid-card-title">Sample Work</h3>
              <p class="grid-card-desc">Frosted blur with color glow</p>
            </div>
            <span class="docs-demo-style-label">glass</span>
          </div>
          <div class="docs-demo-card-wrap card-design--accent-bar">
            <div class="grid-card">
              <h3 class="grid-card-title">Sample Work</h3>
              <p class="grid-card-desc">Gradient left bar</p>
            </div>
            <span class="docs-demo-style-label">accent-bar</span>
          </div>
          <div class="docs-demo-card-wrap card-design--gradient">
            <div class="grid-card">
              <h3 class="grid-card-title">Sample Work</h3>
              <p class="grid-card-desc">Aurora mesh gradient</p>
            </div>
            <span class="docs-demo-style-label">gradient</span>
          </div>
          <div class="docs-demo-card-wrap card-design--elevated">
            <div class="grid-card">
              <h3 class="grid-card-title">Sample Work</h3>
              <p class="grid-card-desc">Floating with spotlight glow</p>
            </div>
            <span class="docs-demo-style-label">elevated</span>
          </div>
          <div class="docs-demo-card-wrap card-design--outlined">
            <div class="grid-card">
              <h3 class="grid-card-title">Sample Work</h3>
              <p class="grid-card-desc">Animated gradient border</p>
            </div>
            <span class="docs-demo-style-label">outlined</span>
          </div>
          <div class="docs-demo-card-wrap card-design--terminal">
            <div class="grid-card">
              <h3 class="grid-card-title">Sample Work</h3>
              <p class="grid-card-desc">IDE with window chrome</p>
            </div>
            <span class="docs-demo-style-label">terminal</span>
          </div>
          <div class="docs-demo-card-wrap card-design--newspaper">
            <div class="grid-card">
              <h3 class="grid-card-title">Sample Work</h3>
              <p class="grid-card-desc">Premium editorial</p>
            </div>
            <span class="docs-demo-style-label">newspaper</span>
          </div>
          <div class="docs-demo-card-wrap card-design--neon">
            <div class="grid-card">
              <h3 class="grid-card-title">Sample Work</h3>
              <p class="grid-card-desc">Cyberpunk glow</p>
            </div>
            <span class="docs-demo-style-label">neon</span>
          </div>
          <div class="docs-demo-card-wrap card-design--holographic">
            <div class="grid-card">
              <h3 class="grid-card-title">Sample Work</h3>
              <p class="grid-card-desc">Rainbow shimmer</p>
            </div>
            <span class="docs-demo-style-label">holographic</span>
          </div>
          <div class="docs-demo-card-wrap card-design--neumorphic">
            <div class="grid-card">
              <h3 class="grid-card-title">Sample Work</h3>
              <p class="grid-card-desc">Soft embossed</p>
            </div>
            <span class="docs-demo-style-label">neumorphic</span>
          </div>
          <div class="docs-demo-card-wrap card-design--spotlight">
            <div class="grid-card">
              <h3 class="grid-card-title">Sample Work</h3>
              <p class="grid-card-desc">Radial light reveal</p>
            </div>
            <span class="docs-demo-style-label">spotlight</span>
          </div>
          <div class="docs-demo-card-wrap card-design--noise">
            <div class="grid-card">
              <h3 class="grid-card-title">Sample Work</h3>
              <p class="grid-card-desc">Textured grain</p>
            </div>
            <span class="docs-demo-style-label">noise</span>
          </div>
        </div>
      </section>

      <!-- Tech Styles -->
      <section class="docs-section">
        <h2 class="docs-heading" id="tech-styles">Tech Stack Styles</h2>
        <p class="docs-text">Set <code>BOARD.techStyle</code> in config. Shown in work modals:</p>

        <div class="docs-tech-demos">
          <div class="docs-tech-demo">
            <span class="docs-tech-demo-label">muted-badges</span>
            <div class="docs-tech-demo-chips">
              <span class="tech-chip tech-chip--muted-badges">Python</span>
              <span class="tech-chip tech-chip--muted-badges">FastAPI</span>
              <span class="tech-chip tech-chip--muted-badges">Docker</span>
            </div>
          </div>
          <div class="docs-tech-demo">
            <span class="docs-tech-demo-label">two-tone</span>
            <div class="docs-tech-demo-chips">
              <span class="tech-chip tech-chip--two-tone">Python</span>
              <span class="tech-chip tech-chip--two-tone">FastAPI</span>
              <span class="tech-chip tech-chip--two-tone">Docker</span>
            </div>
          </div>
          <div class="docs-tech-demo">
            <span class="docs-tech-demo-label">left-border</span>
            <div class="docs-tech-demo-chips">
              <span class="tech-chip tech-chip--left-border">Python</span>
              <span class="tech-chip tech-chip--left-border">FastAPI</span>
              <span class="tech-chip tech-chip--left-border">Docker</span>
            </div>
          </div>
          <div class="docs-tech-demo">
            <span class="docs-tech-demo-label">outlined</span>
            <div class="docs-tech-demo-chips">
              <span class="tech-chip tech-chip--outlined">Python</span>
              <span class="tech-chip tech-chip--outlined">FastAPI</span>
              <span class="tech-chip tech-chip--outlined">Docker</span>
            </div>
          </div>
          <div class="docs-tech-demo">
            <span class="docs-tech-demo-label">filled-pills</span>
            <div class="docs-tech-demo-chips">
              <span class="tech-chip tech-chip--filled-pills">Python</span>
              <span class="tech-chip tech-chip--filled-pills">FastAPI</span>
              <span class="tech-chip tech-chip--filled-pills">Docker</span>
            </div>
          </div>
          <div class="docs-tech-demo">
            <span class="docs-tech-demo-label">dot-separated</span>
            <div class="docs-tech-demo-chips">
              <span class="tech-dot-list">Python · FastAPI · Docker</span>
            </div>
          </div>
          <div class="docs-tech-demo">
            <span class="docs-tech-demo-label">comma-list</span>
            <div class="docs-tech-demo-chips">
              <span class="tech-comma-list">Python, FastAPI, Docker</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Work Types -->
      <section class="docs-section">
        <h2 class="docs-heading" id="work-types">Work Types</h2>
        <p class="docs-text">Set <code>type</code> in frontmatter. Each type gets a colored badge:</p>

        <div class="docs-types-grid">
          <div class="docs-type-item">
            <span class="type-badge" data-type="oss">OSS</span>
            <span class="docs-type-desc">Open source contributions</span>
          </div>
          <div class="docs-type-item">
            <span class="type-badge" data-type="project">Project</span>
            <span class="docs-type-desc">Personal or professional projects</span>
          </div>
          <div class="docs-type-item">
            <span class="type-badge" data-type="writing">Writing</span>
            <span class="docs-type-desc">Blog posts, papers, articles</span>
          </div>
          <div class="docs-type-item">
            <span class="type-badge" data-type="talk">Talk</span>
            <span class="docs-type-desc">Presentations and workshops</span>
          </div>
          <div class="docs-type-item">
            <span class="type-badge" data-type="certification">Cert</span>
            <span class="docs-type-desc">Professional certifications</span>
          </div>
          <div class="docs-type-item">
            <span class="type-badge" data-type="experience">Role</span>
            <span class="docs-type-desc">Job roles and positions</span>
          </div>
          <div class="docs-type-item">
            <span class="type-badge" data-type="conference">Conf</span>
            <span class="docs-type-desc">Conference attendance</span>
          </div>
          <div class="docs-type-item">
            <span class="type-badge" data-type="hackathon">Hack</span>
            <span class="docs-type-desc">Hackathons and competitions</span>
          </div>
          <div class="docs-type-item">
            <span class="type-badge" data-type="meetup">Meetup</span>
            <span class="docs-type-desc">Community events</span>
          </div>
          <div class="docs-type-item">
            <span class="type-badge" data-type="building">Building</span>
            <span class="docs-type-desc">Things being built</span>
          </div>
          <div class="docs-type-item">
            <span class="type-badge" data-type="learning">Learning</span>
            <span class="docs-type-desc">Learning journeys</span>
          </div>
          <div class="docs-type-item">
            <span class="type-badge" data-type="reading">Reading</span>
            <span class="docs-type-desc">Books and reading</span>
          </div>
        </div>
      </section>

      <!-- Modal Features -->
      <section class="docs-section">
        <h2 class="docs-heading" id="modal">Modal Features</h2>
        <p class="docs-text">Click any work card to open a rich detail modal. Add these to frontmatter:</p>

        <div class="docs-features-grid">
          <div class="docs-feature-card">
            <div class="docs-feature-icon">&#x1f5bc;</div>
            <h3>Cover Image</h3>
            <code>image: "url"</code>
            <p>Full-width hero image at top of modal</p>
          </div>
          <div class="docs-feature-card">
            <div class="docs-feature-icon">&#x1f4ca;</div>
            <h3>Highlights</h3>
            <code>highlights:</code>
            <p>Metric cards — "50K+ Users", "99.9% Uptime"</p>
          </div>
          <div class="docs-feature-card">
            <div class="docs-feature-icon">&#x1f5bc;</div>
            <h3>Gallery</h3>
            <code>gallery:</code>
            <p>Image gallery with captions</p>
          </div>
          <div class="docs-feature-card">
            <div class="docs-feature-icon">&#x1f3ac;</div>
            <h3>Video Embed</h3>
            <code>gallery: [type: video]</code>
            <p>YouTube/Vimeo embeds in gallery</p>
          </div>
          <div class="docs-feature-card">
            <div class="docs-feature-icon">&#x1f4c5;</div>
            <h3>Timeline</h3>
            <code>timeline:</code>
            <p>Project milestones as vertical timeline</p>
          </div>
          <div class="docs-feature-card">
            <div class="docs-feature-icon">&#x1f517;</div>
            <h3>Action Links</h3>
            <code>links:</code>
            <p>Buttons: "GitHub →", "Live Demo →"</p>
          </div>
          <div class="docs-feature-card">
            <div class="docs-feature-icon">&#x1f6a6;</div>
            <h3>Status Badge</h3>
            <code>status: active</code>
            <p>Active, Maintained, Archived, In Production</p>
          </div>
          <div class="docs-feature-card">
            <div class="docs-feature-icon">&#x1f527;</div>
            <h3>Tech Stack</h3>
            <code>tech: [...]</code>
            <p>Technology tags with configurable style</p>
          </div>
        </div>
      </section>

      <!-- Frontmatter -->
      <section class="docs-section">
        <h2 class="docs-heading" id="frontmatter">Frontmatter Reference</h2>
        <p class="docs-text">Full list of available fields for each work markdown file:</p>

        <div class="docs-table-wrap">
          <table class="docs-table">
            <thead>
              <tr>
                <th>Field</th>
                <th>Type</th>
                <th>Required</th>
                <th>Description</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><code>title</code></td><td>string</td><td>Yes</td><td>Work title</td></tr>
              <tr><td><code>type</code></td><td>enum</td><td>Yes</td><td>oss, project, writing, talk, certification, experience, conference, hackathon, meetup</td></tr>
              <tr><td><code>pubDatetime</code></td><td>date</td><td>Yes</td><td>Publish date (ISO format)</td></tr>
              <tr><td><code>description</code></td><td>string</td><td>Yes</td><td>One-line summary (shown on cards)</td></tr>
              <tr><td><code>tags</code></td><td>string[]</td><td>Yes</td><td>Tags for filtering</td></tr>
              <tr class="docs-table-divider"><td colspan="4"></td></tr>
              <tr><td><code>featured</code></td><td>boolean</td><td></td><td>Pin to top / first tier</td></tr>
              <tr><td><code>draft</code></td><td>boolean</td><td></td><td>Hide from production build</td></tr>
              <tr><td><code>tech</code></td><td>string[]</td><td></td><td>Tech stack tags for modal</td></tr>
              <tr><td><code>status</code></td><td>enum</td><td></td><td>active, maintained, archived, in-production</td></tr>
              <tr><td><code>image</code></td><td>string</td><td></td><td>Cover image URL</td></tr>
              <tr><td><code>organization</code></td><td>string</td><td></td><td>Company or project name</td></tr>
              <tr><td><code>organizationUrl</code></td><td>string</td><td></td><td>Link for organization</td></tr>
              <tr><td><code>role</code></td><td>string</td><td></td><td>Your role in this work</td></tr>
              <tr><td><code>links</code></td><td>array</td><td></td><td>Action buttons: [&#123;label, url&#125;]</td></tr>
              <tr class="docs-table-divider"><td colspan="4"></td></tr>
              <tr><td><code>highlights</code></td><td>array</td><td></td><td>Metric cards: [&#123;label, value&#125;]</td></tr>
              <tr><td><code>gallery</code></td><td>array</td><td></td><td>Media: [&#123;src, caption, type&#125;]</td></tr>
              <tr><td><code>timeline</code></td><td>array</td><td></td><td>Milestones: [&#123;date, title, description&#125;]</td></tr>
              <tr><td><code>cardStyle</code></td><td>enum</td><td></td><td>Visual card style (see Card Styles)</td></tr>
              <tr class="docs-table-divider"><td colspan="4"></td></tr>
              <tr><td><code>modDatetime</code></td><td>date</td><td></td><td>Last modified date</td></tr>
              <tr><td><code>ogImage</code></td><td>string</td><td></td><td>Custom OG image</td></tr>
              <tr><td><code>canonicalURL</code></td><td>string</td><td></td><td>Canonical URL (if cross-posted)</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Configuration File -->
      <section class="docs-section">
        <h2 class="docs-heading" id="config">Configuration</h2>
        <p class="docs-text">Everything you need to configure lives in <code>src/config.ts</code>:</p>

        <div class="docs-config-grid">
          <div class="docs-config-card">
            <h3>SITE</h3>
            <p>URL, title, author, description, theme settings, OG image, language</p>
          </div>
          <div class="docs-config-card">
            <h3>PROFILE</h3>
            <p>Name, tagline, photo, role, organization, location, SEO keywords</p>
          </div>
          <div class="docs-config-card">
            <h3>SOCIALS_CONFIG</h3>
            <p>Social links — icons are mapped automatically from the name</p>
          </div>
          <div class="docs-config-card">
            <h3>SECTIONS</h3>
            <p>Toggle homepage sections: About, Experience, Skills, Contact</p>
          </div>
          <div class="docs-config-card">
            <h3>BOARD</h3>
            <p>Board layout, recent count, tech stack display style</p>
          </div>
          <div class="docs-config-card">
            <h3>CONNECT</h3>
            <p>Calendly/booking page settings (enable/disable)</p>
          </div>
          <div class="docs-config-card">
            <h3>EXPERIENCE</h3>
            <p>Career timeline entries: role, company, dates, description</p>
          </div>
          <div class="docs-config-card">
            <h3>SKILLS</h3>
            <p>Grouped skill categories with items</p>
          </div>
        </div>
      </section>

      <!-- Theming -->
      <section class="docs-section">
        <h2 class="docs-heading" id="theming">Theming</h2>
        <p class="docs-text">All colors are CSS custom properties in <code>src/styles/global.css</code>:</p>

        <div class="docs-theme-demo">
          <div class="docs-color-row">
            <div class="docs-color-swatch" style="background: var(--background); border: 1px solid var(--border);"></div>
            <code>--background</code>
            <span class="docs-color-desc">Page background</span>
          </div>
          <div class="docs-color-row">
            <div class="docs-color-swatch" style="background: var(--foreground);"></div>
            <code>--foreground</code>
            <span class="docs-color-desc">Text color</span>
          </div>
          <div class="docs-color-row">
            <div class="docs-color-swatch" style="background: var(--accent);"></div>
            <code>--accent</code>
            <span class="docs-color-desc">Brand color (links, badges, highlights)</span>
          </div>
          <div class="docs-color-row">
            <div class="docs-color-swatch" style="background: var(--muted);"></div>
            <code>--muted</code>
            <span class="docs-color-desc">Backgrounds for cards, chips</span>
          </div>
          <div class="docs-color-row">
            <div class="docs-color-swatch" style="background: var(--border);"></div>
            <code>--border</code>
            <span class="docs-color-desc">Borders and dividers</span>
          </div>
        </div>

        <div class="docs-callout">
          <strong>To change your brand color:</strong> update <code>--accent</code> in both the <code>:root</code> (light) and <code>[data-theme="dark"]</code> blocks.
        </div>
      </section>

      <!-- File Structure -->
      <section class="docs-section">
        <h2 class="docs-heading" id="structure">What You Edit</h2>

        <div class="docs-file-tree">
          <div class="docs-file-entry docs-file-primary">
            <span class="docs-file-icon">&#x1f4dd;</span>
            <code>src/config.ts</code>
            <span class="docs-file-desc">All personal data & settings</span>
          </div>
          <div class="docs-file-entry docs-file-primary">
            <span class="docs-file-icon">&#x1f4c1;</span>
            <code>src/data/works/*.md</code>
            <span class="docs-file-desc">Your work items</span>
          </div>
          <div class="docs-file-entry docs-file-primary">
            <span class="docs-file-icon">&#x1f5bc;</span>
            <code>public/</code>
            <span class="docs-file-desc">Profile photo, favicon, images</span>
          </div>
          <div class="docs-file-entry docs-file-secondary">
            <span class="docs-file-icon">&#x1f3a8;</span>
            <code>src/styles/global.css</code>
            <span class="docs-file-desc">Visual customization (optional)</span>

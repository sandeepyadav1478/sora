---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import NavSidebar from "@/components/NavSidebar.astro";
import Footer from "@/components/Footer.astro";
import WorkModal from "@/components/WorkModal.astro";
import getSortedWorks from "@/utils/getSortedWorks";
import { SITE, BOARD } from "@/config";

const allWorks = await getCollection("works");
const sortedWorks = getSortedWorks(allWorks);

const typeLabelMap: Record<string, string> = {
  oss: "OSS",
  project: "Project",
  writing: "Writing",
  talk: "Talk",
  certification: "Cert",
  experience: "Role",
  conference: "Conf",
  hackathon: "Hack",
  meetup: "Meetup",
  building: "Building",
  learning: "Learning",
  reading: "Reading",
};

const typeEyebrowMap: Record<string, string> = {
  oss: "Open Source",
  project: "Case Study",
  writing: "Article",
  talk: "Talk",
  certification: "Certification",
  experience: "Experience",
  conference: "Conference",
  hackathon: "Hackathon",
  meetup: "Meetup",
  building: "Building",
  learning: "Learning",
  reading: "Reading",
};

const statusLabelMap: Record<string, { label: string; cls: string }> = {
  "active": { label: "Active", cls: "status-active" },
  "maintained": { label: "Maintained", cls: "status-maintained" },
  "in-production": { label: "In Production", cls: "status-active" },
  "archived": { label: "Archived", cls: "status-archived" },
};

type GroupedWorks = {
  year: number;
  months: {
    month: string;
    works: typeof sortedWorks;
  }[];
}[];

const grouped: GroupedWorks = [];
const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];

for (const work of sortedWorks) {
  const date = new Date(work.data.modDatetime ?? work.data.pubDatetime);
  const year = date.getFullYear();
  const month = monthNames[date.getMonth()];

  let yearGroup = grouped.find(g => g.year === year);
  if (!yearGroup) {
    yearGroup = { year, months: [] };
    grouped.push(yearGroup);
  }

  let monthGroup = yearGroup.months.find(m => m.month === month);
  if (!monthGroup) {
    monthGroup = { month, works: [] };
    yearGroup.months.push(monthGroup);
  }

  monthGroup.works.push(work);
}
---

<Layout title={`Archives | ${SITE.title}`}>
  <NavSidebar />
  <main id="main-content" data-pagefind-body class="app-layout post-main">
    <h1 class="page-title main-content">Archives</h1>
    <p class="page-desc page-desc-muted">All works, ordered chronologically.</p>

    {grouped.map(({ year, months }) => (
      <section class="archive-year-section">
        <h2 class="archive-year-heading">
          {year}
          <sup class="archive-count">{months.reduce((sum, m) => sum + m.works.length, 0)}</sup>
        </h2>

        {months.map(({ month, works }) => (
          <div class="archive-month-group">
            <div class="archive-month-label">
              {month}
              <sup class="archive-count">{works.length}</sup>
            </div>
            <ul class="archive-month-list">
              {works.map(work => {
                const date = new Date(work.data.modDatetime ?? work.data.pubDatetime);
                const displayDate = date.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
                const isUpdated = work.data.modDatetime && work.data.modDatetime !== work.data.pubDatetime;
                return (
                  <li class="archive-item">
                    <a href={`/#${work.id}`} class="archive-item-title" data-work-trigger={work.id}>{work.data.title}</a>
                    <div class="archive-item-meta">
                      <span class="type-badge">{typeLabelMap[work.data.type] || work.data.type}</span>
                      <time datetime={date.toISOString()}>
                        {isUpdated && <span class="archive-updated-label">Updated: </span>}
                        {displayDate}
                      </time>
                    </div>
                    <p class="archive-item-desc">{work.data.description}</p>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </section>
    ))}

    {sortedWorks.map(async (work) => {
      const { Content } = await render(work);
      const img = work.data.image;
      const imgSrc = typeof img === "object" && img?.src ? img.src : typeof img === "string" ? img : null;
      const displayDate = new Date(work.data.modDatetime ?? work.data.pubDatetime)
        .toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
      const eyebrow = typeEyebrowMap[work.data.type] || work.data.type;
      const statusInfo = work.data.status ? statusLabelMap[work.data.status] : null;
      const highlights = work.data.highlights ?? [];
      const tech = work.data.tech ?? [];
      const gallery = work.data.gallery ?? [];
      const timeline = work.data.timeline ?? [];
      return (
        <div data-work-template={work.id} class="hidden">
          <article class="modal-article">
            {imgSrc && (
              <div class="modal-cover">
                <img src={imgSrc} alt={work.data.title} />
                <div class="modal-cover-overlay"></div>
              </div>
            )}

            <div class="modal-body">
              <p class="modal-eyebrow">{eyebrow}</p>
              <h1 class="modal-title">{work.data.title}</h1>
              <p class="modal-subtitle">{work.data.description}</p>

              <div class="modal-meta-row">
                {work.data.organization && (
                  <span class="modal-meta-item">
                    <span class="modal-meta-label">Org</span>
                    {work.data.organizationUrl && (
                      <img
                        src={`https://www.google.com/s2/favicons?domain=${new URL(work.data.organizationUrl).hostname}&sz=32`}
                        alt=""
                        class="org-favicon"
                        width="14"
                        height="14"
                        loading="lazy"
                      />
                    )}
                    {work.data.organization}
                  </span>
                )}
                {work.data.role && (
                  <span class="modal-meta-item">
                    <span class="modal-meta-label">Role</span>
                    {work.data.role}
                  </span>
                )}
                <span class="modal-meta-item">
                  <span class="modal-meta-label">Date</span>
                  {displayDate}
                </span>
                {statusInfo && (
                  <span class:list={["status-badge", statusInfo.cls]}>
                    {statusInfo.label}
                  </span>
                )}
              </div>

              <div class="modal-tags">
                {work.data.tags.map((t: string) => (
                  <span class="tag-chip">#{t}</span>
                ))}
              </div>

              {work.data.links && work.data.links.length > 0 && (
                <div class="modal-link-bar">
                  {work.data.links.map((link: { url: string; label: string }) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="modal-action-btn"
                    >
                      {link.label} &rarr;
                    </a>
                  ))}
                </div>
              )}

              <hr class="modal-divider" />

              {highlights.length > 0 && (
                <div class="modal-highlights">
                  {highlights.map(h => (
                    <div class="modal-highlight-card">
                      <span class="modal-highlight-value">{h.value}</span>
                      <span class="modal-highlight-label">{h.label}</span>
                    </div>
                  ))}
                </div>
              )}

              {gallery.length > 0 && (
                <div class="modal-gallery">
                  {gallery.map(item => (
                    <figure class="modal-gallery-item" data-gallery-type={item.type}>
                      {item.type === "video" ? (
                        <div class="modal-gallery-video">
                          <iframe src={item.src} title={item.caption || ""}></iframe>
                          <div class="video-theater-overlay">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect>
                              <polyline points="17 2 12 7 7 2"></polyline>
                            </svg>
                          </div>
                        </div>
                      ) : (
                        <img src={item.src} alt={item.caption || ""} loading="lazy" />
                      )}
                      {item.caption && <figcaption>{item.caption}</figcaption>}
                    </figure>
                  ))}
                </div>
              )}

              {timeline.length > 0 && (
                <div class="modal-timeline">
                  <h3 class="modal-timeline-heading">Timeline</h3>
                  <ol class="modal-timeline-list">
                    {timeline.map((entry, i) => (
                      <li class:list={["modal-timeline-entry", i === timeline.length - 1 && "modal-timeline-entry-last"]}>
                        <div class="modal-timeline-dot"></div>
                        <div class="modal-timeline-content">
                          <span class="modal-timeline-date">{entry.date}</span>
                          <strong class="modal-timeline-title">{entry.title}</strong>
                          {entry.description && <p class="modal-timeline-desc">{entry.description}</p>}
                        </div>
                      </li>
                    ))}
                  </ol>
                </div>
              )}

              <div class="app-prose max-w-none modal-prose">
                <Content />
              </div>

              {tech.length > 0 && (
                <div class="modal-tech">
                  <h3 class="modal-tech-heading">Tech Stack</h3>
                  <div class="modal-tech-list">
                    {tech.map(t => <span class={`tech-chip tech-chip--${BOARD.techStyle}`}>{t}</span>)}
                  </div>
                </div>
              )}
            </div>
          </article>
        </div>
      );
    })}

    <WorkModal />
  </main>
  <Footer />
</Layout>

<script src="../scripts/modal.ts"></script>

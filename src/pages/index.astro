---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Hero from "@/components/Hero.astro";
import AboutSection from "@/components/AboutSection.astro";
import FilterTabs from "@/components/FilterTabs.astro";
import WorkCard from "@/components/WorkCard.astro";
import WorkModal from "@/components/WorkModal.astro";
import ExperienceTimeline from "@/components/ExperienceTimeline.astro";
import SkillsSection from "@/components/SkillsSection.astro";
import ContactSection from "@/components/ContactSection.astro";
import getSortedWorks from "@/utils/getSortedWorks";
import { SECTIONS } from "@/config";

const allWorks = await getCollection("works");
const sortedWorks = getSortedWorks(allWorks);

const typeLabelMap: Record<string, string> = {
  oss: "OSS",
  project: "Project",
  writing: "Writing",
  talk: "Talk",
  certification: "Cert",
  experience: "Experience",
};
---

<Layout scrollSmooth>
  <Header />
  <main id="main-content" data-pagefind-body class="app-layout">
    <Hero />

    {SECTIONS.showAbout && <AboutSection />}

    {/* === THE BOARD === */}
    <section id="works" class="pt-8 pb-6">
      <ul>
        {sortedWorks.map(work => <WorkCard {...work} />)}
      </ul>
    </section>

    {SECTIONS.showExperience && <ExperienceTimeline />}
    {SECTIONS.showSkills && <SkillsSection />}
    {SECTIONS.showContact && <ContactSection />}

    {/* Pre-rendered work content (hidden, cloned into modal by JS) */}
    {sortedWorks.map(async work => {
      const { Content } = await render(work);
      const img = work.data.image;
      const imgSrc = typeof img === "object" && img?.src ? img.src : typeof img === "string" ? img : null;
      const displayDate = new Date(work.data.modDatetime ?? work.data.pubDatetime)
        .toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
      return (
        <div data-work-template={work.id} class="hidden">
          <article class="modal-article">
            {imgSrc && (
              <div class="modal-cover">
                <img src={imgSrc} alt={work.data.title} />
              </div>
            )}

            <div class="modal-body">
              <h1 class="text-2xl font-bold text-accent">{work.data.title}</h1>

              <div class="modal-meta">
                <span class="type-badge">{typeLabelMap[work.data.type]}</span>
                <span class="text-sm opacity-80">{displayDate}</span>
                {work.data.organization && (
                  <span class="modal-org">at {work.data.organization}</span>
                )}
              </div>

              <div class="modal-tags">
                {work.data.tags.map(tag => (
                  <span class="tag-chip">#{tag}</span>
                ))}
              </div>

              <hr class="modal-divider" />

              <div class="app-prose max-w-none">
                <Content />
              </div>

              {work.data.links && work.data.links.length > 0 && (
                <div class="modal-actions">
                  {work.data.links.map(link => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="modal-action-btn"
                    >
                      {link.label} &rarr;
                    </a>
                  ))}
                </div>
              )}
            </div>
          </article>
        </div>
      );
    })}

    <WorkModal />
  </main>
  <FilterTabs />
  <Footer />
</Layout>

<script src="../scripts/modal.ts"></script>

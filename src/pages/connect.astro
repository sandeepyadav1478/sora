---
import Layout from "@/layouts/Layout.astro";
import NavSidebar from "@/components/NavSidebar.astro";
import Footer from "@/components/Footer.astro";
import { SITE, CONNECT } from "@/config";

if (!CONNECT.enabled) return Astro.redirect("/");
---

<Layout title={`Connect | ${SITE.title}`}>
  <NavSidebar />
  <main id="main-content" class="app-layout">
    <section class="connect-section">
      <div class="connect-header">
        <h1 class="page-title">{CONNECT.heading}</h1>
        <p class="connect-subheading">{CONNECT.subheading}</p>
      </div>
      <div class="connect-embed">
        <iframe
          src={CONNECT.calendlyUrl}
          title="Schedule a meeting"
          class="connect-iframe"
          loading="lazy"
        ></iframe>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .connect-embed {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    overflow: hidden;
    min-height: 660px;
  }
  .connect-iframe {
    width: 100%;
    height: 700px;
    border: none;
    background: var(--background);
  }
  @media (min-width: 640px) {
    .connect-iframe {
      height: 750px;
    }
  }
</style>

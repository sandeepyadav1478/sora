---
import { EXPERIENCE } from "@/config";
---

{EXPERIENCE.length > 0 && (
  <section id="experience" class="experience-section">
    <h2 class="experience-heading">Experience</h2>
    <div class="experience-list">
      {EXPERIENCE.map(entry => (
        <div class="experience-entry">
          <div class="experience-dot" />
          <div class="experience-header">
            <h3 class="experience-role">{entry.role}</h3>
            <span class="experience-separator">at</span>
            {entry.companyUrl ? (
              <a
                href={entry.companyUrl}
                target="_blank"
                rel="noopener"
                class="experience-company-link"
              >
                {entry.company}
              </a>
            ) : (
              <span class="experience-company-text">{entry.company}</span>
            )}
          </div>
          <p class="experience-dates">
            {entry.startDate} — {entry.endDate}
          </p>
          <p class="experience-desc">{entry.description}</p>
        </div>
      ))}
    </div>
  </section>
)}

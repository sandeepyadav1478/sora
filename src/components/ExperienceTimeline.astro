---
import { EXPERIENCE, CLIENTS, SECTIONS, COMPETENCY_AREAS } from "@/config";

const zapIcon = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`;
const areaIcon = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`;

const showClients = SECTIONS.showClients && CLIENTS.items.length > 0;
---

{EXPERIENCE.length > 0 && (
  <section id="experience" class="experience-section">
    <h2 class="experience-heading">Work Experience</h2>

    {/* Competency areas grid */}
    {COMPETENCY_AREAS.length > 0 && (
      <div class="comp-grid">
        {COMPETENCY_AREAS.map(area => (
          <div class="comp-card">
            <div class="comp-card-icon" set:html={areaIcon} />
            <h3 class="comp-card-title">{area.title}</h3>
            <p class="comp-card-desc">{area.description}</p>
          </div>
        ))}
      </div>
    )}

    <div class="experience-list">
      {EXPERIENCE.map((entry) => {
        const isCurrent = entry.endDate === "Present";
        const faviconUrl = entry.companyUrl
          ? `https://www.google.com/s2/favicons?domain=${new URL(entry.companyUrl).hostname}&sz=64`
          : null;
        const logoSrc = entry.companyLogo || faviconUrl;
        return (
          <div class:list={["exp-card", isCurrent && "exp-card--current"]}>
            <div class="exp-card-header">
              {logoSrc ? (
                <div class="exp-logo">
                  <img src={logoSrc} alt="" width="40" height="40" loading="lazy" />
                </div>
              ) : (
                <div class="exp-logo exp-logo--fallback">
                  <span>{entry.company.charAt(0)}</span>
                </div>
              )}
              <div class="exp-card-title">
                <h3 class="exp-role">{entry.role}</h3>
                <div class="exp-company-row">
                  {entry.companyUrl ? (
                    <a href={entry.companyUrl} target="_blank" rel="noopener" class="exp-company-link">
                      {entry.company}
                    </a>
                  ) : (
                    <span class="exp-company-text">{entry.company}</span>
                  )}
                  <span class="exp-dates">{entry.startDate} — {entry.endDate}</span>
                </div>
              </div>
              {isCurrent && <span class="exp-current-badge">Current</span>}
            </div>

            <p class="exp-desc">{entry.description}</p>

            {entry.caseStudies && entry.caseStudies.length > 0 && (
              <div class="exp-case-studies">
                {entry.caseStudies.map(cs => (
                  <div class="exp-case-card">
                    <div class="exp-case-header">
                      <svg class="exp-case-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="18" x="3" y="3" rx="2" />
                        <path d="M7 7h10" /><path d="M7 12h10" /><path d="M7 17h10" />
                      </svg>
                      <span class="exp-case-title">{cs.title}</span>
                    </div>
                    <p class="exp-case-desc">{cs.description}</p>
                    {cs.tech && cs.tech.length > 0 && (
                      <div class="exp-case-tech">
                        {cs.tech.map(t => (
                          <span class="exp-case-tech-pill">{t}</span>
                        ))}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}

            {entry.achievements && entry.achievements.length > 0 && (
              <div class="exp-achievements">
                {entry.achievements.map(a => (
                  <div class="exp-achievement-card">
                    <span class="exp-zap" set:html={zapIcon} />
                    <span>{a}</span>
                  </div>
                ))}
              </div>
            )}

            {entry.skills && entry.skills.length > 0 && (
              <div class="exp-skills">
                {entry.skills.map(s => (
                  <span class="exp-skill-pill">{s}</span>
                ))}
              </div>
            )}
          </div>
        );
      })}
    </div>

    {/* Trusted clients inline in experience section */}
    {showClients && (
      <div class="exp-clients" id="clients">
        <span class="exp-clients-label">{CLIENTS.heading}</span>
        <div class="exp-clients-row">
          {CLIENTS.items.map(client => (
            <div class="exp-client-item">
              {client.url ? (
                <a href={client.url} target="_blank" rel="noopener noreferrer" class="exp-client-link" title={client.name}>
                  <img src={client.logo} alt={client.name} class="exp-client-logo" loading="lazy" />
                  {!client.hideWordmark && <span class="exp-client-name">{client.name}</span>}
                </a>
              ) : (
                <span class="exp-client-link" title={client.name}>
                  <img src={client.logo} alt={client.name} class="exp-client-logo" loading="lazy" />
                  {!client.hideWordmark && <span class="exp-client-name">{client.name}</span>}
                </span>
              )}
            </div>
          ))}
        </div>
      </div>
    )}
  </section>
)}

---
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import { SITE, CONNECT } from "@/config";
---

{/* Desktop: fixed left sidebar */}
<nav class="nav-sidebar" aria-label="Site navigation">
  <a href="/" class="nav-sidebar-link nav-back-link" data-back style="display:none">&larr; <span class="nav-back-text">Back</span></a>
  <a href="/#works" class="nav-sidebar-link">Works <span class="nav-arrow">&rarr;</span></a>
  <a href="/tags" class="nav-sidebar-link">Tags <span class="nav-arrow">&rarr;</span></a>
  <a href="/about" class="nav-sidebar-link">About <span class="nav-arrow">&rarr;</span></a>
  {CONNECT.enabled && (
    <a href="/connect" class="nav-sidebar-link">1:1 <span class="nav-arrow">&rarr;</span></a>
  )}
  <a href="/archives" class="nav-sidebar-link nav-sidebar-icon" title="Archives" aria-label="Archives">
    <IconArchive class="nav-icon-desktop" />
  </a>
  <a href="/search" class="nav-sidebar-link nav-sidebar-icon" title="Search" aria-label="Search">
    <IconSearch class="nav-icon-desktop" />
  </a>
  {SITE.lightAndDarkMode && (
    <button
      id="theme-btn"
      class="nav-sidebar-link nav-sidebar-icon"
      title="Toggle theme"
      aria-label="Toggle theme"
      aria-live="polite"
    >
      <IconMoon class="nav-theme-icon nav-theme-icon--moon" />
      <IconSunHigh class="nav-theme-icon nav-theme-icon--sun" />
    </button>
  )}
</nav>

{/* Mobile: top bar */}
<header class="nav-mobile-bar app-layout">
  <a href="/" class="nav-back-mobile" data-back style="display:none">&larr; <span class="nav-back-text">Back</span></a>
  <div class="nav-mobile-links">
    <a href="/#works" class="nav-mobile-link">Works</a>
    <a href="/tags" class="nav-mobile-link">Tags</a>
    <a href="/about" class="nav-mobile-link">About</a>
    {CONNECT.enabled && (
      <a href="/connect" class="nav-mobile-link">1:1</a>
    )}
    <a href="/archives" class="nav-mobile-icon" title="Archives" aria-label="Archives">
      <IconArchive class="nav-icon-mobile" />
    </a>
    <a href="/search" class="nav-mobile-icon" title="Search" aria-label="Search">
      <IconSearch class="nav-icon-mobile" />
    </a>
    {SITE.lightAndDarkMode && (
      <button
        id="theme-btn-mobile"
        class="nav-mobile-icon"
        title="Toggle theme"
        aria-label="Toggle theme"
        aria-live="polite"
      >
        <IconMoon class="nav-theme-icon-mobile--moon" />
        <IconSunHigh class="nav-theme-icon-mobile--sun" />
      </button>
    )}
  </div>
</header>

<script>
  let savedScrollY = 0;

  document.addEventListener("click", e => {
    const link = (e.target as HTMLElement).closest<HTMLAnchorElement>("a.tag-link");
    if (link && link.href.includes("/tags?t=")) {
      savedScrollY = window.scrollY;
      sessionStorage.setItem("backToWorks", String(savedScrollY));
    }
  });

  function initBackNav() {
    const onTags = window.location.pathname.startsWith("/tags");
    const hasParam = new URLSearchParams(window.location.search).has("t");
    const hasBackData = sessionStorage.getItem("backToWorks") !== null;
    const show = onTags && hasParam && hasBackData;

    if (!onTags) sessionStorage.removeItem("backToWorks");

    document.querySelectorAll<HTMLAnchorElement>("[data-back]").forEach(link => {
      link.style.display = show ? "" : "none";
      link.onclick = show ? (e => {
        e.preventDefault();
        const scrollY = parseInt(sessionStorage.getItem("backToWorks") || "0", 10);
        sessionStorage.removeItem("backToWorks");
        window.location.href = "/";
        requestAnimationFrame(() => {
          setTimeout(() => window.scrollTo(0, scrollY), 100);
        });
      }) : null;
    });

  }
  initBackNav();
  document.addEventListener("astro:page-load", initBackNav);
</script>

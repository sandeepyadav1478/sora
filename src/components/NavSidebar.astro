---
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import { SITE, SECTIONS, CONNECT, USES, READING } from "@/config";
const isTemplate = "isTemplate" in SITE && SITE.isTemplate;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

{/* Desktop: fixed left sidebar — flat dot navigation */}
<nav class="nav-sidebar" aria-label="Site navigation">
  <div class="nav-dots" id="nav-dots">
    <a href="/#works" class="nav-dot-item" data-nav-id="works">Projects</a>
    {SECTIONS.showExperience && <a href="/#experience" class="nav-dot-item" data-nav-id="experience">Experience</a>}
    {SECTIONS.showSkills && <a href="/#skills" class="nav-dot-item" data-nav-id="skills">Skills</a>}
    {(SECTIONS.showEducation || SECTIONS.showAwards) && <a href="/#education" class="nav-dot-item" data-nav-id="education">Education</a>}
    <a href="/#testimonials" class="nav-dot-item" data-nav-id="testimonials">Testimonials</a>
    <a href="/#sharing" class="nav-dot-item" data-nav-id="sharing">Contact</a>
  </div>

  {/* ── Page links & utilities ── */}
  <div class="nav-utils">
    {USES.enabled && <a href="/uses" class:list={["nav-page-link", currentPath === "/uses" && "is-active"]}>Uses</a>}
    {READING.enabled && <a href="/reading" class:list={["nav-page-link", currentPath === "/reading" && "is-active"]}>Reading</a>}
    {CONNECT.enabled && <a href="/connect" class:list={["nav-page-link", currentPath === "/connect" && "is-active"]}>1:1</a>}
    {isTemplate && <a href="/docs" class:list={["nav-page-link nav-page-link--docs", currentPath === "/docs" && "is-active"]}>Docs</a>}
    <div class="nav-icon-row">
      <a href="/archives" class="nav-sidebar-icon" title="Archives" aria-label="Archives">
        <IconArchive class="nav-icon-desktop" />
      </a>
      <a href="/search" class="nav-sidebar-icon" title="Search" aria-label="Search">
        <IconSearch class="nav-icon-desktop" />
      </a>
      {SITE.lightAndDarkMode && (
        <button
          id="theme-btn"
          class="nav-sidebar-icon"
          title="Toggle theme"
          aria-label="Toggle theme"
          aria-live="polite"
        >
          <IconMoon class="nav-theme-icon nav-theme-icon--moon" />
          <IconSunHigh class="nav-theme-icon nav-theme-icon--sun" />
        </button>
      )}
      {isTemplate && (
        <button
          id="shuffle-btn"
          class="nav-sidebar-icon"
          title="Shuffle hero style"
          aria-label="Shuffle hero style"
        >
          <svg class="nav-icon-desktop" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8" /><line x1="4" y1="20" x2="21" y2="3" /><polyline points="21 16 21 21 16 21" /><line x1="15" y1="15" x2="21" y2="21" /><line x1="4" y1="4" x2="9" y2="9" /></svg>
        </button>
      )}
    </div>
  </div>
</nav>

{/* Hero floating icons — visible before sidebar appears, homepage only */}
{currentPath === "/" && <div class="hero-float-icons" id="hero-float-icons">
  <a href="/search" class="hero-float-icon" title="Search" aria-label="Search">
    <IconSearch class="hero-float-svg" />
  </a>
  {SITE.lightAndDarkMode && (
    <button
      id="theme-btn-hero"
      class="hero-float-icon"
      title="Toggle theme"
      aria-label="Toggle theme"
      aria-live="polite"
    >
      <IconMoon class="hero-float-theme--moon" />
      <IconSunHigh class="hero-float-theme--sun" />
    </button>
  )}
  {isTemplate && (
    <button
      id="shuffle-btn-hero"
      class="hero-float-icon"
      title="Shuffle hero style"
      aria-label="Shuffle hero style"
    >
      <svg class="hero-float-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8" /><line x1="4" y1="20" x2="21" y2="3" /><polyline points="21 16 21 21 16 21" /><line x1="15" y1="15" x2="21" y2="21" /><line x1="4" y1="4" x2="9" y2="9" /></svg>
    </button>
  )}
</div>}

{/* Mobile: top bar */}
<header class="nav-mobile-bar app-layout">
  <a href="/" class="nav-back-mobile" data-back style="display:none">&larr; <span class="nav-back-text">Back</span></a>
  <div class="nav-mobile-links">
    <a href="/#works" class="nav-mobile-link">Works</a>
    <a href="/about" class="nav-mobile-link">About</a>
    {USES.enabled && (
      <a href="/uses" class="nav-mobile-link">Uses</a>
    )}
    {READING.enabled && (
      <a href="/reading" class="nav-mobile-link">Reading</a>
    )}
    {CONNECT.enabled && (
      <a href="/connect" class="nav-mobile-link">1:1</a>
    )}
    {isTemplate && (
      <a href="/docs" class:list={["nav-mobile-link nav-mobile-link--docs", currentPath === "/docs" && "is-active"]}>Docs</a>
    )}
    <a href="/archives" class="nav-mobile-icon" title="Archives" aria-label="Archives">
      <IconArchive class="nav-icon-mobile" />
    </a>
    <a href="/search" class="nav-mobile-icon" title="Search" aria-label="Search">
      <IconSearch class="nav-icon-mobile" />
    </a>
    {SITE.lightAndDarkMode && (
      <button
        id="theme-btn-mobile"
        class="nav-mobile-icon"
        title="Toggle theme"
        aria-label="Toggle theme"
        aria-live="polite"
      >
        <IconMoon class="nav-theme-icon-mobile--moon" />
        <IconSunHigh class="nav-theme-icon-mobile--sun" />
      </button>
    )}
  </div>
</header>

<script>
  function initNavDots() {
    const sidebar = document.querySelector<HTMLElement>(".nav-sidebar");
    const dotsWrap = document.getElementById("nav-dots");
    const items = document.querySelectorAll<HTMLElement>(".nav-dot-item[data-nav-id]");

    const heroFloatIcons = document.getElementById("hero-float-icons");

    if (window.location.pathname !== "/") {
      items.forEach(i => i.classList.remove("is-active"));
      if (heroFloatIcons) heroFloatIcons.classList.add("is-hidden");
      return;
    }

    const sectionMap = new Map<string, HTMLElement>();
    items.forEach(item => {
      const id = item.dataset.navId!;
      const el = document.getElementById(id);
      if (el) sectionMap.set(id, el);
    });

    const aboutEl = document.getElementById("about");

    function updateActive() {
      if (aboutEl && sidebar) {
        const aboutBottom = aboutEl.getBoundingClientRect().bottom;
        if (aboutBottom > 0) {
          sidebar.classList.add("nav-hidden");
          if (heroFloatIcons) heroFloatIcons.classList.remove("is-hidden");
        } else {
          sidebar.classList.remove("nav-hidden");
          if (heroFloatIcons) heroFloatIcons.classList.add("is-hidden");
        }
      }

      let topId = "";
      const threshold = 140;
      sectionMap.forEach((el, id) => {
        if (el.getBoundingClientRect().top <= threshold) {
          topId = id;
        }
      });

      items.forEach(i => i.classList.remove("is-active"));

      if (topId) {
        const active = document.querySelector<HTMLElement>(`.nav-dot-item[data-nav-id="${topId}"]`);
        if (active) active.classList.add("is-active");
      }
    }

    let raf = 0;
    function onScroll() {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(updateActive);
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    updateActive();

    return () => window.removeEventListener("scroll", onScroll);
  }

  let cleanup = initNavDots();
  document.addEventListener("astro:page-load", () => {
    if (cleanup) cleanup();
    cleanup = initNavDots();
  });
</script>

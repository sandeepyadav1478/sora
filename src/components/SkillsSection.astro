---
import { SKILLS } from "@/config";
---

{SKILLS.length > 0 && (
  <section id="skills" class="pt-12 pb-6 border-b border-border">
    <h2 class="text-2xl font-semibold tracking-wide">Skills & Stack</h2>
    <div class="mt-6 space-y-4">
      {SKILLS.map(group => (
        <div>
          <h3 class="text-sm font-medium uppercase tracking-wider opacity-60">
            {group.category}
          </h3>
          <div class="mt-2 flex flex-wrap gap-2">
            {group.items.map(skill => (
              <span class="rounded border border-border px-3 py-1 text-sm transition-all duration-150 hover:border-accent hover:text-accent hover:-translate-y-px hover:shadow-sm">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
)}

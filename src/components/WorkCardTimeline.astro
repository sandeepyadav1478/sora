---
import type { CollectionEntry } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = CollectionEntry<"works">;

const { id, data } = Astro.props;
const { title, type, description, pubDatetime, tags, organization, featured, status, badgeColor } = data;

const typeLabelMap: Record<string, string> = {
  oss: "OSS",
  project: "Project",
  writing: "Writing",
  talk: "Talk",
  certification: "Cert",
  experience: "Role",
  conference: "Conf",
  hackathon: "Hack",
  meetup: "Meetup",
  building: "Building",
  learning: "Learning",
  reading: "Reading",
};

const statusLabelMap: Record<string, { label: string; cls: string }> = {
  "active": { label: "Active", cls: "status-active" },
  "maintained": { label: "Maintained", cls: "status-maintained" },
  "in-production": { label: "In Production", cls: "status-active" },
  "archived": { label: "Archived", cls: "status-archived" },
};

const tz = SITE.timezone;
const dateStr = dayjs(pubDatetime).tz(tz).format("MMM YYYY");
---

<li class="work-item timeline-item" data-type={type} data-tags={tags.join(",")}>
  <div class="timeline-dot-wrap">
    <div class:list={["timeline-dot", featured && "timeline-dot-featured"]}></div>
  </div>
  <div
    class:list={[
      "work-card-trigger timeline-card",
      featured && "timeline-card-featured",
    ]}
    data-work-id={id}
    role="button"
    tabindex="0"
  >
    <div class="timeline-date">{dateStr}</div>
    <div class="timeline-badges">
      <span class:list={["compact-type-badge", `type-badge--${type}`]} style={badgeColor ? `--badge-color:${badgeColor};background:color-mix(in srgb,var(--badge-color) 12%,transparent);color:var(--badge-color)` : undefined}>{typeLabelMap[type]}</span>
      {featured && <span class="featured-badge">Featured</span>}
      {status && statusLabelMap[status] && (
        <span class:list={["status-badge", statusLabelMap[status].cls]}>
          {statusLabelMap[status].label}
        </span>
      )}
    </div>
    <h3 class="timeline-title">{title}</h3>
    {organization && <span class="timeline-org">at {organization}</span>}
    <p class="timeline-desc">{description}</p>
    <div class="timeline-tags">
      {tags.slice(0, 4).map(tag => (
        <span class="tag-chip">#{tag}</span>
      ))}
    </div>
  </div>
</li>

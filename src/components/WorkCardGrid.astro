---
import type { CollectionEntry } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = CollectionEntry<"works">;

const { id, data } = Astro.props;
const { title, type, description, pubDatetime, tags, organization, featured, status, cardStyle, badgeColor } = data;

const typeLabelMap: Record<string, string> = {
  oss: "OSS",
  project: "Project",
  writing: "Writing",
  talk: "Talk",
  certification: "Cert",
  experience: "Role",
  conference: "Conf",
  hackathon: "Hack",
  meetup: "Meetup",
  building: "Building",
  learning: "Learning",
  reading: "Reading",
};

const statusLabelMap: Record<string, { label: string; cls: string }> = {
  "active": { label: "Active", cls: "status-active" },
  "maintained": { label: "Maintained", cls: "status-maintained" },
  "in-production": { label: "In Production", cls: "status-active" },
  "archived": { label: "Archived", cls: "status-archived" },
};

const tz = SITE.timezone;
const dateStr = dayjs(pubDatetime).tz(tz).format("MMM YYYY");
const img = data.image;
const imgSrc = typeof img === "object" && img?.src ? img.src : typeof img === "string" ? img : null;
---

<li class:list={["work-item", cardStyle && `card-design--${cardStyle}`]} data-type={type} data-tags={tags.join(",")}>
  <div
    class:list={[
      "work-card-trigger grid-card",
      featured && "grid-card-featured",
    ]}
    data-work-id={id}
    role="button"
    tabindex="0"
  >
    {imgSrc && (
      <div class="grid-card-thumb">
        <img src={imgSrc} alt="" loading="lazy" />
      </div>
    )}
    <div class="grid-card-body">
      <div class="grid-card-header">
        <div class="grid-card-badges">
          <span class:list={["compact-type-badge", `type-badge--${type}`]} style={badgeColor ? `--badge-color:${badgeColor};background:color-mix(in srgb,var(--badge-color) 12%,transparent);color:var(--badge-color)` : undefined}>{typeLabelMap[type]}</span>
          {featured && <span class="featured-badge">Featured</span>}
          {status && statusLabelMap[status] && (
            <span class:list={["status-badge", statusLabelMap[status].cls]}>
              {statusLabelMap[status].label}
            </span>
          )}
        </div>
        <span class="grid-card-date">{dateStr}</span>
      </div>
      <h3 class="grid-card-title">{title}</h3>
      {organization && <span class="grid-card-org">at {organization}</span>}
      <p class="grid-card-desc">{description}</p>
      <div class="grid-card-footer">
        <div class="grid-card-tags">
          {tags.slice(0, 3).map(tag => (
            <span class="tag-chip">#{tag}</span>
          ))}
          {tags.length > 3 && <span class="grid-card-tags-overflow">+{tags.length - 3}</span>}
        </div>
      </div>
    </div>
  </div>
  <template class="compact-preview-tpl">
    {imgSrc && (
      <div class="compact-preview-thumb">
        <img src={imgSrc} alt="" loading="lazy" />
        <div class="compact-preview-fade"></div>
      </div>
    )}
    <div class="compact-preview-body">
      <p class="compact-preview-desc">{description}</p>
      <div class="compact-preview-tags">
        {tags.slice(0, 4).map(tag => (
          <span class="tag-chip">#{tag}</span>
        ))}
        {tags.length > 4 && <span class="compact-preview-more">+{tags.length - 4}</span>}
      </div>
    </div>
  </template>
</li>

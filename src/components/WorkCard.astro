---
import type { CollectionEntry } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = CollectionEntry<"works">;

const { id, data } = Astro.props;
const { title, type, description, pubDatetime, modDatetime, endDatetime, ongoing, tags, organization, role, featured, status, cardStyle } = data;

const statusLabelMap: Record<string, { label: string; cls: string }> = {
  "active": { label: "Active", cls: "status-active" },
  "maintained": { label: "Maintained", cls: "status-maintained" },
  "in-production": { label: "In Production", cls: "status-active" },
  "archived": { label: "Archived", cls: "status-archived" },
};

const typeLabelMap: Record<string, string> = {
  oss: "OSS",
  project: "Project",
  writing: "Writing",
  talk: "Talk",
  certification: "Cert",
  experience: "Role",
  conference: "Conf",
  hackathon: "Hack",
  meetup: "Meetup",
};

const tz = SITE.timezone;
const startDate = dayjs(pubDatetime).tz(tz).format("MMM YYYY");
const endDate = ongoing ? "Present" : endDatetime ? dayjs(endDatetime).tz(tz).format("MMM YYYY") : null;
const dateDisplay = endDate ? `${startDate} — ${endDate}` : startDate;
---

<li class:list={["work-item my-4", cardStyle && `card-design--${cardStyle}`]} data-type={type} data-tags={tags.join(",")}>
  <div
    class:list={[
      "work-card-trigger w-full cursor-pointer rounded-lg border p-4 text-left transition-colors",
      featured
        ? "border-accent/25 bg-accent/5 hover:border-accent/40 hover:bg-accent/10"
        : "border-transparent hover:border-border hover:bg-muted/30",
    ]}
    data-work-id={id}
    role="button"
    tabindex="0"
  >
    <div class="flex flex-wrap items-baseline gap-2">
      <span class:list={["type-badge", `type-badge--${type}`]}>{typeLabelMap[type]}</span>
      <h3 class="text-lg font-medium text-accent">
        {title}
      </h3>
      {organization && (
        <span class="text-sm opacity-50">at {organization}</span>
      )}
    </div>
    {role && (
      <p class="mt-0.5 text-sm font-medium opacity-70">{role}</p>
    )}
    <div class="mt-1 flex flex-wrap items-center gap-2">
      <span class="text-xs opacity-50">{dateDisplay}</span>
      {featured && <span class="featured-badge">Featured</span>}
      {status && statusLabelMap[status] && (
        <span class:list={["status-badge", statusLabelMap[status].cls]}>
          {statusLabelMap[status].label}
        </span>
      )}
    </div>
    <p class="mt-1 text-sm opacity-70">{description}</p>
    <div class="mt-2 flex flex-wrap gap-2">
      {tags.map(tag => (
        <a href={`/tags?t=${encodeURIComponent(tag)}`} class="tag-chip tag-link" data-tag={tag}>#{tag}</a>
      ))}
    </div>
  </div>
</li>

---
import type { CollectionEntry } from "astro:content";
import Datetime from "./Datetime.astro";

type Props = CollectionEntry<"works">;

const { id, data } = Astro.props;
const { title, type, description, pubDatetime, modDatetime, tags, organization } = data;

const typeLabelMap: Record<string, string> = {
  oss: "OSS",
  project: "Project",
  writing: "Writing",
  talk: "Talk",
  certification: "Cert",
};
---

<li class="work-item my-4" data-type={type}>
  <button
    class="work-card-trigger w-full cursor-pointer rounded-lg border border-transparent p-4 text-left transition-colors hover:border-border hover:bg-muted/30"
    data-work-id={id}
  >
    <div class="flex flex-wrap items-baseline gap-2">
      <span class="type-badge">{typeLabelMap[type]}</span>
      <h3
        class="inline-block text-lg font-medium text-accent decoration-dashed underline-offset-4 group-hover:underline"
      >
        {title}
      </h3>
      {organization && (
        <span class="text-sm opacity-60">at {organization}</span>
      )}
    </div>
    <Datetime {pubDatetime} {modDatetime} class="mt-1" />
    <p class="mt-1 opacity-80">{description}</p>
    <div class="mt-2 flex flex-wrap gap-2">
      {tags.map(tag => <span class="tag-chip">#{tag}</span>)}
    </div>
  </button>
</li>

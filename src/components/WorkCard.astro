---
import type { CollectionEntry } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import { SITE } from "@/config";
import { getHighlightIcon } from "@/utils/highlightIcons";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = CollectionEntry<"works">;

const { id, data } = Astro.props;
const { title, type, description, pubDatetime, modDatetime, endDatetime, ongoing, tags, organization, organizationUrl, role, featured, status, links, highlights, cardStyle, badgeColor } = data;

const statusLabelMap: Record<string, { label: string; cls: string }> = {
  "active": { label: "Active", cls: "status-active" },
  "maintained": { label: "Maintained", cls: "status-maintained" },
  "in-production": { label: "In Production", cls: "status-active" },
  "archived": { label: "Archived", cls: "status-archived" },
};

const typeLabelMap: Record<string, string> = {
  oss: "OSS",
  project: "Project",
  writing: "Writing",
  talk: "Talk",
  certification: "Cert",
  experience: "Role",
  conference: "Conf",
  hackathon: "Hack",
  meetup: "Meetup",
  building: "Building",
  learning: "Learning",
  reading: "Reading",
};

const tz = SITE.timezone;
const startDate = dayjs(pubDatetime).tz(tz).format("MMM YYYY");
const endDate = ongoing ? "Present" : endDatetime ? dayjs(endDatetime).tz(tz).format("MMM YYYY") : null;
const dateDisplay = endDate ? `${startDate} — ${endDate}` : startDate;

const orgFavicon = organizationUrl
  ? `https://www.google.com/s2/favicons?domain=${new URL(organizationUrl).hostname}&sz=32`
  : null;

const githubLink = links?.find(l => l.url.includes("github.com"));
const externalLinks = links?.filter(l => !l.url.includes("github.com")) ?? [];
---

<li class:list={["work-item", cardStyle && `card-design--${cardStyle}`]} data-type={type} data-tags={tags.join(",")}>
  <div
    class:list={[
      "work-card-trigger work-card-body",
      featured && "work-card-body-featured",
    ]}
    data-work-id={id}
    role="button"
    tabindex="0"
  >
    <div class="work-card-header">
      <span class:list={["type-badge", `type-badge--${type}`]} style={badgeColor ? `--badge-color:${badgeColor};background:color-mix(in srgb,var(--badge-color) 12%,transparent);color:var(--badge-color)` : undefined}>{typeLabelMap[type]}</span>
      <h3 class="work-card-title">
        {title}
      </h3>
      {featured && (
        <span class="featured-badge">
          <svg class="card-icon card-icon--star" width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          Featured
        </span>
      )}
    </div>

    <div class="work-card-meta">
      {organization && (
        <span class="work-card-org">
          {orgFavicon && <img src={orgFavicon} alt="" width="14" height="14" loading="lazy" class="card-org-favicon" />}
          <svg class="card-icon card-icon--org" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>
          {organization}
        </span>
      )}
      {role && (
        <span class="work-card-role-inline">
          <svg class="card-icon card-icon--role" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          {role}
        </span>
      )}
      <span class="work-card-date">
        <svg class="card-icon card-icon--date" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
        {dateDisplay}
      </span>
      {status && statusLabelMap[status] && (
        <span class:list={["status-badge", statusLabelMap[status].cls]}>
          {statusLabelMap[status].label}
        </span>
      )}
    </div>

    <p class="work-card-desc">{description}</p>

    {highlights && highlights.length > 0 && (
      <div class="work-card-highlights">
        {highlights.map(h => {
          const ico = getHighlightIcon(h.icon);
          return (
            <span class="work-card-highlight">
              <svg class="card-icon card-icon--highlight" width="11" height="11" viewBox={ico.viewBox} fill={ico.fill ? "currentColor" : "none"} stroke={ico.fill ? "none" : "currentColor"} stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={ico.d}/></svg>
              <strong>{h.value}</strong> {h.label}
            </span>
          );
        })}
      </div>
    )}

    <div class="work-card-footer">
      <div class="work-card-tags">
        {tags.map(tag => (
          <a href={`/tags?t=${encodeURIComponent(tag)}`} class="tag-chip tag-link" data-tag={tag}>#{tag}</a>
        ))}
      </div>
      {(githubLink || externalLinks.length > 0) && (
        <div class="work-card-links">
          {githubLink && (
            <a href={githubLink.url} target="_blank" rel="noopener" class="work-card-link work-card-link--github" onclick="event.stopPropagation()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              {githubLink.label}
            </a>
          )}
          {externalLinks.slice(0, 2).map(link => (
            <a href={link.url} target="_blank" rel="noopener" class="work-card-link" onclick="event.stopPropagation()">
              <svg class="card-icon card-icon--link" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
              {link.label}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</li>

---
import type { CollectionEntry } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import { SITE } from "@/config";
import { getHighlightIcon } from "@/utils/highlightIcons";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = CollectionEntry<"works">;

const { id, data } = Astro.props;
const {
  title, type, description, pubDatetime, endDatetime, ongoing, tags, tech,
  organization, organizationUrl, role, featured, status, links, highlights,
  cardStyle, badgeColor,
} = data;

const typeLabelMap: Record<string, string> = {
  oss: "OSS", project: "Project", writing: "Writing", talk: "Talk",
  certification: "Cert", experience: "Role", conference: "Conf",
  hackathon: "Hack", meetup: "Meetup", building: "Building",
  learning: "Learning", reading: "Reading",
};

const statusLabelMap: Record<string, { label: string; cls: string }> = {
  "active": { label: "Active", cls: "status-active" },
  "maintained": { label: "Maintained", cls: "status-maintained" },
  "in-production": { label: "In Production", cls: "status-active" },
  "archived": { label: "Archived", cls: "status-archived" },
};

const tz = SITE.timezone;
const startDate = dayjs(pubDatetime).tz(tz).format("MMM YYYY");
const endDate = ongoing ? "Present" : endDatetime ? dayjs(endDatetime).tz(tz).format("MMM YYYY") : null;
const dateDisplay = endDate ? `${startDate} — ${endDate}` : startDate;

const orgFavicon = organizationUrl
  ? `https://www.google.com/s2/favicons?domain=${new URL(organizationUrl).hostname}&sz=32`
  : null;

const githubLink = links?.find(l => l.url.includes("github.com"));
const externalLinks = links?.filter(l => !l.url.includes("github.com")) ?? [];

const typeColorMap: Record<string, string> = {
  oss: "#22c55e", project: "#3b82f6", writing: "#8b5cf6", talk: "#f97316",
  certification: "#eab308", experience: "#6366f1", conference: "#a855f7",
  hackathon: "#f59e0b", meetup: "#06b6d4", building: "#ec4899",
  learning: "#14b8a6", reading: "#d946ef",
};
const cardAccent = badgeColor || typeColorMap[type] || "var(--clr-primary)";

const descBullets = description.includes("•")
  ? description.split("•").map(s => s.trim()).filter(Boolean)
  : description.includes(";")
    ? description.split(";").map(s => s.trim()).filter(Boolean)
    : [description];
const hasBullets = descBullets.length > 1;
---

<li class:list={["work-item work-item--featured", cardStyle && `card-design--${cardStyle}`]} data-type={type} data-tags={tags.join(",")}>
  <div
    class="work-card-trigger featured-card"
    data-work-id={id}
    role="button"
    tabindex="0"
    style={`--card-accent: ${cardAccent}`}
  >
    <div class="featured-card-top">
      <div class="featured-card-type-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          {type === "oss" && <><circle cx="12" cy="12" r="10"/><path d="m8 12 3 3 5-5"/></>}
          {type === "project" && <><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 7h10"/><path d="M7 12h10"/><path d="M7 17h10"/></>}
          {type === "writing" && <><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></>}
          {type === "hackathon" && <><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></>}
          {type === "conference" && <><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Z"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2Z"/></>}
          {type === "experience" && <><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><path d="M12 12v.01"/></>}
          {type === "certification" && <><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></>}
          {type === "meetup" && <><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></>}
          {type === "building" && <><path d="M2 20h20"/><path d="M5 20V8l7-5 7 5v12"/><path d="M9 20v-4h6v4"/></>}
          {type === "learning" && <><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></>}
          {type === "reading" && <><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></>}
          {type === "talk" && <><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></>}
          {!["oss", "project", "writing", "hackathon", "conference", "experience", "certification", "meetup", "building", "learning", "reading", "talk"].includes(type) && <><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 7h10"/></>}
        </svg>
      </div>
      {status && statusLabelMap[status] && (
        <span class:list={["status-badge featured-card-status", statusLabelMap[status].cls]}>
          <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4" fill="currentColor"/></svg>
          {statusLabelMap[status].label}
        </span>
      )}
    </div>

    <h3 class="featured-card-title">{title}</h3>

    <div class="featured-card-meta">
      {organization && (
        <span class="featured-card-org">
          {orgFavicon && <img src={orgFavicon} alt="" width="14" height="14" loading="lazy" class="card-org-favicon" />}
          {organization}
        </span>
      )}
      {role && (
        <span class="featured-card-role">
          <svg class="card-icon card-icon--role" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          {role}
        </span>
      )}
    </div>

    {hasBullets ? (
      <ul class="featured-card-bullets">
        {descBullets.map(b => (
          <li class="featured-card-bullet">
            <svg class="card-icon card-icon--accent" width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            <span>{b}</span>
          </li>
        ))}
      </ul>
    ) : (
      <p class="featured-card-desc">{description}</p>
    )}

    {highlights && highlights.length > 0 && (
      <div class="featured-card-metrics">
        {highlights.map(h => {
          const ico = getHighlightIcon(h.icon);
          return (
            <div class="featured-card-metric">
              <div class="featured-card-metric-top">
                <svg class="card-icon card-icon--accent" width="14" height="14" viewBox={ico.viewBox} fill={ico.fill ? "currentColor" : "none"} stroke={ico.fill ? "none" : "currentColor"} stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={ico.d}/></svg>
                <span class="featured-card-metric-value">{h.value}</span>
              </div>
              <span class="featured-card-metric-label">{h.label}</span>
            </div>
          );
        })}
      </div>
    )}

    {tech && tech.length > 0 && (
      <div class="featured-card-tech">
        {tech.slice(0, 6).map(t => (
          <span class="featured-card-tech-pill">{t}</span>
        ))}
        {tech.length > 6 && <span class="featured-card-tech-pill featured-card-tech-more">+{tech.length - 6}</span>}
      </div>
    )}

    <div class="featured-card-footer">
      <div class="featured-card-links">
        {githubLink && (
          <a href={githubLink.url} target="_blank" rel="noopener" class="featured-card-link featured-card-link--github" onclick="event.stopPropagation()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            {githubLink.label}
          </a>
        )}
        {externalLinks.slice(0, 2).map(link => (
          <a href={link.url} target="_blank" rel="noopener" class="featured-card-link" onclick="event.stopPropagation()">
            <svg class="card-icon card-icon--link" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
            {link.label}
          </a>
        ))}
      </div>
      <span class="featured-card-arrow">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </span>
    </div>
  </div>
</li>

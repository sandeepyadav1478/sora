---
const tabs = [
  { filter: "all", label: "All" },
  { filter: "oss", label: "OSS" },
  { filter: "project", label: "Projects" },
  { filter: "writing", label: "Writing" },
  { filter: "talk", label: "Talks" },
  { filter: "certification", label: "Certs" },
  { filter: "experience", label: "Experience" },
];
---

<aside class="filter-sidebar">
  <nav class="filter-nav">
    {
      tabs.map(tab => (
        <a
          href="#"
          data-filter={tab.filter}
          class:list={[
            "filter-link",
            { active: tab.filter === "all" },
          ]}
        >
          {tab.label}
        </a>
      ))
    }
  </nav>
</aside>

<script>
  function initFilterTabs() {
    const links = document.querySelectorAll<HTMLAnchorElement>(".filter-link");
    const items = document.querySelectorAll<HTMLElement>(".work-item");

    links.forEach(link => {
      link.addEventListener("click", e => {
        e.preventDefault();
        const filter = link.dataset.filter;
        links.forEach(l => l.classList.remove("active"));
        link.classList.add("active");
        items.forEach(item => {
          if (filter === "all" || item.dataset.type === filter) {
            item.style.display = "";
          } else {
            item.style.display = "none";
          }
        });
      });
    });
  }

  initFilterTabs();
  document.addEventListener("astro:page-load", initFilterTabs);
</script>

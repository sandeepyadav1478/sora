---
import Socials from "./Socials.astro";
import { PROFILE } from "@/config";
---

<section id="hero" class="pt-8 pb-6">
  <div class="hero-row">
    <div class="hero-photo-wrap">
      <img
        src={PROFILE.photo}
        alt={PROFILE.name}
        class="rounded-full object-cover border-2 border-border"
      />
    </div>
    <div class="hero-info text-center sm:text-left">
      <h1 class="text-3xl font-bold sm:text-4xl"><a href="/" class="hover:text-accent transition-colors">{PROFILE.name}</a></h1>
      {(PROFILE.role || PROFILE.organization) && (
        <p class="mt-1 text-base">
          <span class="opacity-80">{PROFILE.role}</span>
          {PROFILE.role && PROFILE.organization && (
            <span class="opacity-50"> at </span>
          )}
          {PROFILE.organization && (
            PROFILE.organizationUrl
              ? <a href={PROFILE.organizationUrl} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">{PROFILE.organization}</a>
              : <span class="text-accent">{PROFILE.organization}</span>
          )}
        </p>
      )}
      {PROFILE.location && (
        <p class="mt-0.5 text-sm opacity-50">{PROFILE.location}</p>
      )}
      <p class="mt-1.5 text-sm opacity-60 max-w-lg">{PROFILE.tagline}</p>
      <div class="mt-3">
        <Socials />
      </div>
    </div>
  </div>
</section>

<script>
  function syncHeroPhoto() {
    const info = document.querySelector<HTMLElement>(".hero-info");
    const wrap = document.querySelector<HTMLElement>(".hero-photo-wrap");
    if (!info || !wrap || window.innerWidth < 640) return;
    const h = info.offsetHeight;
    wrap.style.width = h + "px";
    wrap.style.height = h + "px";
  }

  let resizeTimer: ReturnType<typeof setTimeout>;
  function debouncedSync() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(syncHeroPhoto, 100);
  }

  syncHeroPhoto();
  window.addEventListener("resize", debouncedSync);
  document.addEventListener("astro:page-load", syncHeroPhoto);
</script>

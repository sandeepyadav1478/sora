---
import Socials from "./Socials.astro";
import { PROFILE } from "@/config";
---

<section id="hero" class="hero-section">
  <div class="hero-row">
    <div class="hero-photo-wrap">
      <img
        src={PROFILE.photo}
        alt={PROFILE.name}
        class="hero-photo"
      />
    </div>
    <div class="hero-info">
      <h1 class="hero-name"><a href="/">{PROFILE.name}</a></h1>
      {(PROFILE.role || PROFILE.organization) && (
        <p class="hero-role">
          <span class="hero-role-text">{PROFILE.role}</span>
          {PROFILE.role && PROFILE.organization && (
            <span class="hero-role-separator"> at </span>
          )}
          {PROFILE.organization && (
            PROFILE.organizationUrl
              ? <a href={PROFILE.organizationUrl} target="_blank" rel="noopener noreferrer" class="hero-org-link">{PROFILE.organization}</a>
              : <span class="hero-org-text">{PROFILE.organization}</span>
          )}
        </p>
      )}
      {PROFILE.location && (
        <p class="hero-location">{PROFILE.location}</p>
      )}
      <p class="hero-tagline">{PROFILE.tagline}</p>
      <div class="hero-socials">
        <Socials />
      </div>
    </div>
  </div>
</section>

<script>
  function syncHeroPhoto() {
    const info = document.querySelector<HTMLElement>(".hero-info");
    const wrap = document.querySelector<HTMLElement>(".hero-photo-wrap");
    if (!info || !wrap || window.innerWidth < 640) return;
    const h = info.offsetHeight;
    wrap.style.width = h + "px";
    wrap.style.height = h + "px";
  }

  let resizeTimer: ReturnType<typeof setTimeout>;
  function debouncedSync() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(syncHeroPhoto, 100);
  }

  syncHeroPhoto();
  window.addEventListener("resize", debouncedSync);
  document.addEventListener("astro:page-load", syncHeroPhoto);
</script>

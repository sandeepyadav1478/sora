---
import type { CollectionEntry } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = CollectionEntry<"works">;

const { id, data } = Astro.props;
const { title, type, pubDatetime, tags, organization, status, description, image, links, cardStyle, badgeColor } = data;
const img = typeof image === "object" && image?.src ? image.src : typeof image === "string" ? image : null;

const typeLabelMap: Record<string, string> = {
  oss: "OSS",
  project: "Project",
  writing: "Writing",
  talk: "Talk",
  certification: "Cert",
  experience: "Role",
  conference: "Conf",
  hackathon: "Hack",
  meetup: "Meetup",
  building: "Building",
  learning: "Learning",
  reading: "Reading",
};

const statusLabelMap: Record<string, { label: string; cls: string }> = {
  "active": { label: "Active", cls: "status-active" },
  "maintained": { label: "Maintained", cls: "status-maintained" },
  "in-production": { label: "In Production", cls: "status-active" },
  "archived": { label: "Archived", cls: "status-archived" },
};

const tz = SITE.timezone;
const dateStr = dayjs(pubDatetime).tz(tz).format("MMM YYYY");
const githubLink = links?.find(l => l.url.includes("github.com"));
---

<li class:list={["work-item", cardStyle && `card-design--${cardStyle}`]} data-type={type} data-tags={tags.join(",")}>
  <div
    class="work-card-trigger compact-card"
    data-work-id={id}
    role="button"
    tabindex="0"
  >
    <span class:list={["compact-type-badge", `type-badge--${type}`]} style={badgeColor ? `--badge-color:${badgeColor};background:color-mix(in srgb,var(--badge-color) 12%,transparent);color:var(--badge-color)` : undefined}>{typeLabelMap[type]}</span>
    <span class="compact-title">{title}</span>
    {organization && <span class="compact-org">at {organization}</span>}
    {status && statusLabelMap[status] && (
      <span class:list={["status-badge", statusLabelMap[status].cls]}>
        {statusLabelMap[status].label}
      </span>
    )}
    {githubLink && (
      <a href={githubLink.url} target="_blank" rel="noopener" class="compact-github" onclick="event.stopPropagation()" title="GitHub">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
    )}
    <span class="compact-date">{dateStr}</span>
  </div>
  <template class="compact-preview-tpl">
    {img && (
      <div class="compact-preview-thumb">
        <img src={img} alt="" loading="lazy" />
        <div class="compact-preview-fade"></div>
      </div>
    )}
    <div class="compact-preview-body">
      <p class="compact-preview-desc">{description}</p>
      <div class="compact-preview-tags">
        {tags.slice(0, 4).map(tag => (
          <span class="tag-chip">#{tag}</span>
        ))}
        {tags.length > 4 && <span class="compact-preview-more">+{tags.length - 4}</span>}
      </div>
    </div>
  </template>
</li>
